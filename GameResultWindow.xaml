<Window x:Class="TicTacToePro.GameResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Result" Height="200" Width="300">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="ResultText" FontSize="18" FontWeight="Bold"/>
            <Button Content="New Game" Click="NewGame_Click" Margin="20,10"/>
        </StackPanel>
    </Grid>
</Window>
