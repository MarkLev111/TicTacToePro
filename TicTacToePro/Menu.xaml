<Window x:Class="TicTacToePro.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TicTacToePro" Height="200" Width="300"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid>
            <Button Name="Login" Content="Авторизоваться" Click="Login" Margin="20,10,20,153" Visibility="Visible" />
            <Button Content="" Name="Logout" Click="Logout" Visibility="Hidden" Margin="20,10,20,153" />
        </Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30,0,0">
            <Button Content="Локальная игра" Click="Singleplayer" Margin="20,10"/>
            <Button Content="Игра по сети" Click="Multiplayer" Margin="20,10"/>
            <Button Content="Статистика" Click="StatsWindow" Margin="20,10"/>
        </StackPanel>
    </Grid>
</Window>
