<Window x:Class="TicTacToePro.GameResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Результат" Height="200" Width="300"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="ResultText" FontSize="18" FontWeight="Bold"/>
            <Button Content="Играть заново" Click="NewGame_Click" Margin="20,10"/>
        </StackPanel>
    </Grid>
</Window>
