<Window x:Class="TicTacToePro.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика" Height="500" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" Margin="10" Height="210">
            <TextBlock Text="Локальная игра" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#333"/>
            <TextBlock x:Name="Games" FontSize="22" Margin="5"/>
            <TextBlock x:Name="X" FontSize="22" Margin="5"/>
            <TextBlock x:Name="O" FontSize="22" Margin="5"/>
            <TextBlock x:Name="Draw" FontSize="22" Margin="5"/>
        </StackPanel>

        <Rectangle Grid.Column="1" Grid.Row="1" Width="1" Fill="#CCC" Margin="10,40"/>

        <Grid Grid.Column="2" Grid.Row="1" Margin="10" VerticalAlignment="Center" Height="210">
            <StackPanel x:Name="MPPanel">
                <TextBlock Text="Игра по сети" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#333"/>

                <TextBlock x:Name="ErrorText" FontSize="18" Foreground="Crimson" TextWrapping="Wrap" TextAlignment="Center" Visibility="Collapsed" Margin="10"/>
                
                <StackPanel x:Name="StatsDataPanel" Visibility="Visible">
                    <TextBlock x:Name="MPGames" FontSize="22" Margin="5"/>
                    <TextBlock x:Name="MPWins" FontSize="22" Margin="5"/>
                    <TextBlock x:Name="MPLoses" FontSize="22" Margin="5"/>
                    <TextBlock x:Name="MPDraw" FontSize="22" Margin="5"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Button Grid.Row="2" Grid.ColumnSpan="3" Content="Главное меню" 
                FontSize="18" Padding="20,10" HorizontalAlignment="Center"
                Click="Menu_Click" Cursor="Hand" Margin="0,20,0,10"/>
    </Grid>
</Window>