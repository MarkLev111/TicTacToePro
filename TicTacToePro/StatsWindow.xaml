<Window x:Class="TicTacToePro.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicTacToePro"
        mc:Ignorable="d"
        Title="StatsWindow" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="Games" FontSize="32" FontWeight="Bold"/>
            <TextBlock x:Name="X" FontSize="32" FontWeight="Bold"/>
            <TextBlock x:Name="O" FontSize="32" FontWeight="Bold"/>
            <TextBlock x:Name="Draw" FontSize="32" FontWeight="Bold"/>
            <Button Content="Главное меню" FontSize="18" Click="Menu_Click" Margin="20,10"/>
        </StackPanel>
    </Grid>
</Window>
