<Window x:Class="TicTacToePro.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TicTacToePro" Height="200" Width="300"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Button Name="Login" Content="Авторизоваться" Click="Login_Click" Margin="20,10,20,0" Visibility="Visible" />
            <Button Content="" Name="Logout" Click="Logout_Click" Visibility="Hidden" Margin="20,10,20,0" />
        </Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,00,0,0" Grid.Row="1">
            <Button Content="Локальная игра" Click="Singleplayer" Margin="20,10"/>
            <Button Content="Игра по сети" Click="Multiplayer" Margin="20,10"/>
            <Button Content="Статистика" Click="StatsWindow" Margin="20,10"/>
        </StackPanel>
    </Grid>
</Window>
